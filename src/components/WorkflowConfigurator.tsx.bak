"use client";

import { useState, useRef, useCallback } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { 
  Zap, 
  MessageSquare, 
  Mail, 
  FileText, 
  Calendar, 
  Database, 
  Settings, 
  Plus, 
  Trash2, 
  Copy, 
  Play, 
  Pause, 
  Save, 
  Download, 
  Upload, 
  RotateCcw,
  CheckCircle2,
  AlertTriangle,
  Clock,
  ArrowRight,
  GitBranch,
  Filter,
  Target,
  Users,
  TrendingUp,
  Bell,
  Phone,
  DollarSign
} from 'lucide-react';

interface WorkflowNode {
  id: string;
  type: 'trigger' | 'action' | 'condition' | 'end';
  label: string;
  icon: any;
  color: string;
  position: { x: number; y: number };
  config: Record<string, any>;
  connections: string[];
}

interface WorkflowTemplate {
  id: string;
  name: string;
  description: string;
  category: string;
  nodes: WorkflowNode[];
  popularity: number;
  estimatedSavings: string;
}

const nodeTypes = {
  triggers: [
    { type: 'new_lead', label: 'New Lead Received', icon: Users, color: 'green', description: 'Triggered when a new lead comes in' },
    { type: 'client_message', label: 'Client Message', icon: MessageSquare, color: 'blue', description: 'When a client sends a message' },
    { type: 'policy_renewal', label: 'Policy Renewal Due', icon: Calendar, color: 'orange', description: 'Auto-trigger before renewal dates' },
    { type: 'claim_filed', label: 'Claim Filed', icon: FileText, color: 'red', description: 'When a new claim is submitted' },
    { type: 'quote_requested', label: 'Quote Requested', icon: DollarSign, color: 'purple', description: 'When someone requests a quote' }
  ],
  actions: [
    { type: 'send_email', label: 'Send Email', icon: Mail, color: 'blue', description: 'Send automated email response' },
    { type: 'send_sms', label: 'Send SMS', icon: Phone, color: 'green', description: 'Send text message notification' },
    { type: 'create_task', label: 'Create Task', icon: CheckCircle2, color: 'orange', description: 'Add task to your workflow' },
    { type: 'update_crm', label: 'Update CRM', icon: Database, color: 'purple', description: 'Update client information' },
    { type: 'schedule_followup', label: 'Schedule Follow-up', icon: Calendar, color: 'blue', description: 'Auto-schedule next contact' },
    { type: 'generate_quote', label: 'Generate Quote', icon: FileText, color: 'green', description: 'Create insurance quote automatically' },
    { type: 'notify_agent', label: 'Notify Agent', icon: Bell, color: 'yellow', description: 'Alert specific team member' }
  ],
  conditions: [
    { type: 'check_value', label: 'Check Value', icon: Filter, color: 'gray', description: 'Check if value meets criteria' },
    { type: 'time_based', label: 'Time Condition', icon: Clock, color: 'blue', description: 'Execute based on time/date' },
    { type: 'client_type', label: 'Client Type', icon: Target, color: 'purple', description: 'Route based on client category' },
    { type: 'policy_type', label: 'Policy Type', icon: GitBranch, color: 'green', description: 'Branch by insurance type' }
  ]
};

const workflowTemplates: WorkflowTemplate[] = [
  {
    id: 'lead_nurture',
    name: 'Lead Nurturing Sequence',
    description: 'Automatically follow up with new leads and convert them to clients',
    category: 'Sales',
    popularity: 95,
    estimatedSavings: '5 hours/week',
    nodes: [
      { id: '1', type: 'trigger', label: 'New Lead', icon: Users, color: 'green', position: { x: 100, y: 100 }, config: {}, connections: ['2'] },
      { id: '2', type: 'action', label: 'Send Welcome Email', icon: Mail, color: 'blue', position: { x: 300, y: 100 }, config: {}, connections: ['3'] },
      { id: '3', type: 'condition', label: 'Response Received?', icon: Filter, color: 'gray', position: { x: 500, y: 100 }, config: {}, connections: ['4', '5'] },
      { id: '4', type: 'action', label: 'Schedule Call', icon: Phone, color: 'green', position: { x: 700, y: 50 }, config: {}, connections: ['6'] },
      { id: '5', type: 'action', label: 'Follow-up SMS', icon: Phone, color: 'orange', position: { x: 700, y: 150 }, config: {}, connections: ['6'] },
      { id: '6', type: 'end', label: 'Complete', icon: CheckCircle2, color: 'green', position: { x: 900, y: 100 }, config: {}, connections: [] }
    ]
  },
  {
    id: 'policy_renewal',
    name: 'Policy Renewal Automation',
    description: 'Streamline policy renewals with automated reminders and processing',
    category: 'Operations',
    popularity: 88,
    estimatedSavings: '8 hours/week',
    nodes: [
      { id: '1', type: 'trigger', label: 'Renewal Due (30 days)', icon: Calendar, color: 'orange', position: { x: 100, y: 100 }, config: {}, connections: ['2'] },
      { id: '2', type: 'action', label: 'Generate Renewal Quote', icon: FileText, color: 'green', position: { x: 300, y: 100 }, config: {}, connections: ['3'] },
      { id: '3', type: 'action', label: 'Email Client', icon: Mail, color: 'blue', position: { x: 500, y: 100 }, config: {}, connections: ['4'] },
      { id: '4', type: 'condition', label: 'Client Responds?', icon: Filter, color: 'gray', position: { x: 700, y: 100 }, config: {}, connections: ['5', '6'] },
      { id: '5', type: 'action', label: 'Process Renewal', icon: CheckCircle2, color: 'green', position: { x: 900, y: 50 }, config: {}, connections: ['7'] },
      { id: '6', type: 'action', label: 'Follow-up Call', icon: Phone, color: 'orange', position: { x: 900, y: 150 }, config: {}, connections: ['7'] },
      { id: '7', type: 'end', label: 'Complete', icon: CheckCircle2, color: 'green', position: { x: 1100, y: 100 }, config: {}, connections: [] }
    ]
  },
  {
    id: 'claim_processing',
    name: 'Claims Processing Workflow',
    description: 'Automate initial claim processing and client communication',
    category: 'Claims',
    popularity: 82,
    estimatedSavings: '12 hours/week',
    nodes: [
      { id: '1', type: 'trigger', label: 'New Claim Filed', icon: FileText, color: 'red', position: { x: 100, y: 100 }, config: {}, connections: ['2'] },
      { id: '2', type: 'action', label: 'Send Acknowledgment', icon: Mail, color: 'blue', position: { x: 300, y: 100 }, config: {}, connections: ['3'] },
      { id: '3', type: 'condition', label: 'Claim Amount', icon: DollarSign, color: 'purple', position: { x: 500, y: 100 }, config: {}, connections: ['4', '5'] },
      { id: '4', type: 'action', label: 'Auto-Approve', icon: CheckCircle2, color: 'green', position: { x: 700, y: 50 }, config: {}, connections: ['6'] },
      { id: '5', type: 'action', label: 'Assign Adjuster', icon: Users, color: 'orange', position: { x: 700, y: 150 }, config: {}, connections: ['6'] },
      { id: '6', type: 'end', label: 'Complete', icon: CheckCircle2, color: 'green', position: { x: 900, y: 100 }, config: {}, connections: [] }
    ]
  }
];

export default function WorkflowConfigurator() {
  const [activeTab, setActiveTab] = useState<'templates' | 'builder' | 'analytics'>('templates');
  const [selectedTemplate, setSelectedTemplate] = useState<WorkflowTemplate | null>(null);
  const [workflowNodes, setWorkflowNodes] = useState<WorkflowNode[]>([]);
  const [selectedNode, setSelectedNode] = useState<WorkflowNode | null>(null);
  const [draggedNodeType, setDraggedNodeType] = useState<any>(null);
  const [isRunning, setIsRunning] = useState(false);
  const canvasRef = useRef<HTMLDivElement>(null);

  const handleDragStart = (nodeType: any) => {
    setDraggedNodeType(nodeType);
  };

  const handleDrop = useCallback((e: React.DragEvent) => {
    e.preventDefault();
    if (!draggedNodeType || !canvasRef.current) return;

    const rect = canvasRef.current.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;

    const newNode: WorkflowNode = {
      id: `node_${Date.now()}`,
      type: draggedNodeType.type === 'trigger' ? 'trigger' : 
            draggedNodeType.type === 'condition' ? 'condition' : 
            draggedNodeType.type === 'end' ? 'end' : 'action',
      label: draggedNodeType.label,
      icon: draggedNodeType.icon,
      color: draggedNodeType.color,
      position: { x, y },
      config: {},
      connections: []
    };

    setWorkflowNodes(prev => [...prev, newNode]);
    setDraggedNodeType(null);
  }, [draggedNodeType]);

  const handleDragOver = (e: React.DragEvent) => {
    e.preventDefault();
  };

  const loadTemplate = (template: WorkflowTemplate) => {
    setWorkflowNodes(template.nodes);
    setActiveTab('builder');
    setSelectedTemplate(template);
  };

  const clearWorkflow = () => {
    setWorkflowNodes([]);
    setSelectedNode(null);
    setSelectedTemplate(null);
  };

  const runWorkflow = () => {
    setIsRunning(true);
    // Simulate workflow execution
    setTimeout(() => setIsRunning(false), 3000);
  };

  const renderNode = (node: WorkflowNode) => (
    <motion.div
      key={node.id}
      initial={{ scale: 0 }}
      animate={{ scale: 1 }}
      whileHover={{ scale: 1.05 }}
      className={`absolute cursor-pointer p-4 rounded-xl border-2 bg-white shadow-lg min-w-[150px] ${
        selectedNode?.id === node.id ? 'border-blue-500' : 'border-gray-200'
      }`}
      style={{ 
        left: node.position.x, 
        top: node.position.y,
        zIndex: selectedNode?.id === node.id ? 10 : 1
      }}
      onClick={() => setSelectedNode(node)}
    >
      <div className="flex items-center gap-2 mb-2">
        <div className={`p-2 rounded-lg ${
          node.color === 'green' ? 'bg-green-100 text-green-600' :
          node.color === 'blue' ? 'bg-blue-100 text-blue-600' :
          node.color === 'orange' ? 'bg-orange-100 text-orange-600' :
          node.color === 'red' ? 'bg-red-100 text-red-600' :
          node.color === 'purple' ? 'bg-purple-100 text-purple-600' :
          node.color === 'yellow' ? 'bg-yellow-100 text-yellow-600' :
          'bg-gray-100 text-gray-600'
        }`}>
          <node.icon className="w-4 h-4" />
        </div>
        <span className="font-medium text-gray-900 text-sm">{node.label}</span>
      </div>
      
      <div className={`text-xs px-2 py-1 rounded ${
        node.type === 'trigger' ? 'bg-green-100 text-green-600' :
        node.type === 'action' ? 'bg-blue-100 text-blue-600' :
        node.type === 'condition' ? 'bg-orange-100 text-orange-600' :
        'bg-gray-100 text-gray-600'
      }`}>
        {node.type.charAt(0).toUpperCase() + node.type.slice(1)}
      </div>

      {/* Connection points */}
      <div className="absolute -right-3 top-1/2 w-6 h-6 bg-gray-300 rounded-full border-2 border-white transform -translate-y-1/2"></div>
      {node.type !== 'trigger' && (
        <div className="absolute -left-3 top-1/2 w-6 h-6 bg-gray-300 rounded-full border-2 border-white transform -translate-y-1/2"></div>
      )}
    </motion.div>
  );

  const renderTemplates = () => (
    <div className="space-y-6">
      <div className="text-center">
        <h3 className="text-2xl font-bold text-text-primary mb-2">Workflow Templates</h3>
        <p className="text-text-secondary">Start with proven automation workflows</p>
      </div>

      <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {workflowTemplates.map((template) => (
          <motion.div
            key={template.id}
            whileHover={{ y: -5 }}
            className="card-light rounded-xl p-6 border border-gray-200 hover:shadow-lg transition-all cursor-pointer"
            onClick={() => loadTemplate(template)}
          >
            <div className="flex items-center justify-between mb-4">
              <div className={`px-3 py-1 rounded-full text-xs font-medium ${
                template.category === 'Sales' ? 'bg-green-100 text-green-600' :
                template.category === 'Operations' ? 'bg-blue-100 text-blue-600' :
                'bg-purple-100 text-purple-600'
              }`}>
                {template.category}
              </div>
              <div className="flex items-center gap-1 text-yellow-500">
                <Star className="w-4 h-4 fill-current" />
                <span className="text-sm font-medium">{template.popularity}</span>
              </div>
            </div>

            <h4 className="font-semibold text-text-primary mb-2">{template.name}</h4>
            <p className="text-sm text-text-secondary mb-4">{template.description}</p>

            <div className="flex items-center justify-between">
              <div className="flex items-center gap-1 text-green-600">
                <Clock className="w-4 h-4" />
                <span className="text-sm font-medium">Saves {template.estimatedSavings}</span>
              </div>
              <button className="btn-primary px-4 py-2 rounded-lg text-sm">
                Use Template
              </button>
            </div>
          </motion.div>
        ))}
      </div>

      <div className="text-center">
        <button 
          onClick={() => setActiveTab('builder')}
          className="btn-secondary px-8 py-3 rounded-xl font-medium"
        >
          Start From Scratch
        </button>
      </div>
    </div>
  );

  const renderBuilder = () => (
    <div className="grid lg:grid-cols-4 gap-6">
      {/* Node Palette */}
      <div className="lg:col-span-1 space-y-6">
        <div className="card-light rounded-xl p-4">
          <h4 className="font-semibold text-text-primary mb-4">Workflow Controls</h4>
          <div className="flex flex-col gap-2">
            <button
              onClick={runWorkflow}
              disabled={isRunning || workflowNodes.length === 0}
              className="flex items-center justify-center gap-2 btn-primary px-4 py-2 rounded-lg text-sm disabled:opacity-50"
            >
              {isRunning ? <Pause className="w-4 h-4" /> : <Play className="w-4 h-4" />}
              {isRunning ? 'Running...' : 'Test Workflow'}
            </button>
            <button 
              onClick={clearWorkflow}
              className="flex items-center justify-center gap-2 btn-secondary px-4 py-2 rounded-lg text-sm"
            >
              <RotateCcw className="w-4 h-4" />
              Clear All
            </button>
            <button className="flex items-center justify-center gap-2 border border-gray-300 px-4 py-2 rounded-lg text-sm hover:bg-gray-50">
              <Save className="w-4 h-4" />
              Save Workflow
            </button>
          </div>
        </div>

        {/* Triggers */}
        <div className="card-light rounded-xl p-4">
          <h4 className="font-semibold text-text-primary mb-4">Triggers</h4>
          <div className="space-y-2">
            {nodeTypes.triggers.map((nodeType) => (
              <div
                key={nodeType.type}
                draggable
                onDragStart={() => handleDragStart(nodeType)}
                className="p-3 border border-gray-200 rounded-lg cursor-move hover:bg-gray-50 transition-colors"
              >
                <div className="flex items-center gap-2">
                  <div className={`p-1 rounded ${
                    nodeType.color === 'green' ? 'bg-green-100 text-green-600' :
                    nodeType.color === 'blue' ? 'bg-blue-100 text-blue-600' :
                    nodeType.color === 'orange' ? 'bg-orange-100 text-orange-600' :
                    nodeType.color === 'red' ? 'bg-red-100 text-red-600' :
                    'bg-purple-100 text-purple-600'
                  }`}>
                    <nodeType.icon className="w-3 h-3" />
                  </div>
                  <span className="text-sm font-medium text-gray-900">{nodeType.label}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        {/* Actions */}
        <div className="card-light rounded-xl p-4">
          <h4 className="font-semibold text-text-primary mb-4">Actions</h4>
          <div className="space-y-2">
            {nodeTypes.actions.map((nodeType) => (
              <div
                key={nodeType.type}
                draggable
                onDragStart={() => handleDragStart(nodeType)}
                className="p-3 border border-gray-200 rounded-lg cursor-move hover:bg-gray-50 transition-colors"
              >
                <div className="flex items-center gap-2">
                  <div className={`p-1 rounded ${
                    nodeType.color === 'green' ? 'bg-green-100 text-green-600' :
                    nodeType.color === 'blue' ? 'bg-blue-100 text-blue-600' :
                    nodeType.color === 'orange' ? 'bg-orange-100 text-orange-600' :
                    nodeType.color === 'purple' ? 'bg-purple-100 text-purple-600' :
                    'bg-yellow-100 text-yellow-600'
                  }`}>
                    <nodeType.icon className="w-3 h-3" />
                  </div>
                  <span className="text-sm font-medium text-gray-900">{nodeType.label}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        {/* Conditions */}
        <div className="card-light rounded-xl p-4">
          <h4 className="font-semibold text-text-primary mb-4">Conditions</h4>
          <div className="space-y-2">
            {nodeTypes.conditions.map((nodeType) => (
              <div
                key={nodeType.type}
                draggable
                onDragStart={() => handleDragStart(nodeType)}
                className="p-3 border border-gray-200 rounded-lg cursor-move hover:bg-gray-50 transition-colors"
              >
                <div className="flex items-center gap-2">
                  <div className={`p-1 rounded ${
                    nodeType.color === 'gray' ? 'bg-gray-100 text-gray-600' :
                    nodeType.color === 'blue' ? 'bg-blue-100 text-blue-600' :
                    nodeType.color === 'purple' ? 'bg-purple-100 text-purple-600' :
                    'bg-green-100 text-green-600'
                  }`}>
                    <nodeType.icon className="w-3 h-3" />
                  </div>
                  <span className="text-sm font-medium text-gray-900">{nodeType.label}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* Canvas */}
      <div className="lg:col-span-3">
        <div className="card-light rounded-xl p-4 h-[600px]">
          <div className="flex items-center justify-between mb-4">
            <h4 className="font-semibold text-text-primary">
              {selectedTemplate ? `Editing: ${selectedTemplate.name}` : 'Workflow Builder'}
            </h4>
            <div className="flex items-center gap-2">
              {workflowNodes.length > 0 && (
                <span className="text-sm text-text-muted">
                  {workflowNodes.length} nodes
                </span>
              )}
              {isRunning && (
                <div className="flex items-center gap-2 text-green-600">
                  <div className="w-2 h-2 bg-green-600 rounded-full animate-pulse"></div>
                  <span className="text-sm font-medium">Running</span>
                </div>
              )}
            </div>
          </div>

          <div
            ref={canvasRef}
            className="relative w-full h-full border-2 border-dashed border-gray-300 rounded-lg bg-gray-50 overflow-hidden"
            onDrop={handleDrop}
            onDragOver={handleDragOver}
          >
            {workflowNodes.length === 0 ? (
              <div className="absolute inset-0 flex items-center justify-center text-center">
                <div>
                  <Zap className="w-16 h-16 text-gray-400 mx-auto mb-4" />
                  <h5 className="text-lg font-medium text-gray-600 mb-2">Start Building Your Workflow</h5>
                  <p className="text-gray-500 text-sm">
                    Drag and drop elements from the palette or choose a template to get started
                  </p>
                </div>
              </div>
            ) : (
              <>
                {workflowNodes.map(renderNode)}
                
                {/* Connection lines */}
                <svg className="absolute inset-0 w-full h-full pointer-events-none">
                  {workflowNodes.map((node) =>
                    node.connections.map((connectionId) => {
                      const targetNode = workflowNodes.find(n => n.id === connectionId);
                      if (!targetNode) return null;

                      const startX = node.position.x + 150;
                      const startY = node.position.y + 40;
                      const endX = targetNode.position.x;
                      const endY = targetNode.position.y + 40;

                      return (
                        <line
                          key={`${node.id}-${connectionId}`}
                          x1={startX}
                          y1={startY}
                          x2={endX}
                          y2={endY}
                          stroke="#3b82f6"
                          strokeWidth="2"
                          markerEnd="url(#arrowhead)"
                        />
                      );
                    })
                  )}
                  <defs>
                    <marker
                      id="arrowhead"
                      markerWidth="10"
                      markerHeight="7"
                      refX="9"
                      refY="3.5"
                      orient="auto"
                    >
                      <polygon
                        points="0 0, 10 3.5, 0 7"
                        fill="#3b82f6"
                      />
                    </marker>
                  </defs>
                </svg>
              </>
            )}
          </div>
        </div>
      </div>
    </div>
  );

  const renderAnalytics = () => (
    <div className="space-y-6">
      <div className="text-center">
        <h3 className="text-2xl font-bold text-text-primary mb-2">Workflow Analytics</h3>
        <p className="text-text-secondary">Track the performance of your automation workflows</p>
      </div>

      <div className="grid md:grid-cols-3 gap-6">
        <div className="card-light rounded-xl p-6 text-center">
          <div className="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <TrendingUp className="w-6 h-6 text-green-600" />
          </div>
          <div className="text-2xl font-bold text-text-primary mb-1">47</div>
          <div className="text-sm text-text-muted">Active Workflows</div>
        </div>

        <div className="card-light rounded-xl p-6 text-center">
          <div className="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <Clock className="w-6 h-6 text-blue-600" />
          </div>
          <div className="text-2xl font-bold text-text-primary mb-1">127hrs</div>
          <div className="text-sm text-text-muted">Time Saved This Month</div>
        </div>

        <div className="card-light rounded-xl p-6 text-center">
          <div className="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <CheckCircle2 className="w-6 h-6 text-purple-600" />
          </div>
          <div className="text-2xl font-bold text-text-primary mb-1">2,847</div>
          <div className="text-sm text-text-muted">Tasks Completed</div>
        </div>
      </div>

      <div className="grid lg:grid-cols-2 gap-6">
        <div className="card-light rounded-xl p-6">
          <h4 className="font-semibold text-text-primary mb-4">Top Performing Workflows</h4>
          <div className="space-y-4">
            {workflowTemplates.map((template, index) => (
              <div key={template.id} className="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                <div>
                  <div className="font-medium text-text-primary">{template.name}</div>
                  <div className="text-sm text-text-muted">Saves {template.estimatedSavings}</div>
                </div>
                <div className="text-right">
                  <div className="font-semibold text-green-600">{template.popularity}%</div>
                  <div className="text-xs text-text-muted">Efficiency</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div className="card-light rounded-xl p-6">
          <h4 className="font-semibold text-text-primary mb-4">Recent Activity</h4>
          <div className="space-y-4">
            {[
              { action: 'Lead Nurture workflow triggered', time: '2 minutes ago', status: 'success' },
              { action: 'Policy Renewal reminder sent', time: '5 minutes ago', status: 'success' },
              { action: 'Claim Processing workflow started', time: '12 minutes ago', status: 'running' },
              { action: 'Quote Generation completed', time: '18 minutes ago', status: 'success' },
              { action: 'Follow-up email sent', time: '25 minutes ago', status: 'success' }
            ].map((activity, index) => (
              <div key={index} className="flex items-center gap-3">
                <div className={`w-3 h-3 rounded-full ${
                  activity.status === 'success' ? 'bg-green-500' :
                  activity.status === 'running' ? 'bg-blue-500 animate-pulse' :
                  'bg-gray-400'
                }`}></div>
                <div className="flex-1">
                  <div className="text-sm font-medium text-text-primary">{activity.action}</div>
                  <div className="text-xs text-text-muted">{activity.time}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  );

  return (
    <section id="workflow-configurator" className="py-24 px-4 bg-gray-50">
      <div className="max-w-7xl mx-auto">
        <motion.div
          initial={{ opacity: 0, y: 20 }}
          whileInView={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.6 }}
          className="text-center mb-12"
        >
          <h2 className="text-4xl sm:text-5xl font-bold font-display mb-4 text-text-primary">
            Visual Workflow Designer
          </h2>
          <p className="text-xl text-text-secondary max-w-3xl mx-auto">
            Design powerful automation workflows with our intuitive drag-and-drop interface. No coding required.
          </p>
        </motion.div>

        {/* Tab Navigation */}
        <div className="flex justify-center mb-8">
          <div className="bg-white p-1 rounded-xl shadow-sm border border-gray-200">
            {[
              { key: 'templates', label: 'Templates', icon: FileText },
              { key: 'builder', label: 'Builder', icon: Settings },
              { key: 'analytics', label: 'Analytics', icon: TrendingUp }
            ].map(({ key, label, icon: Icon }) => (
              <button
                key={key}
                onClick={() => setActiveTab(key as typeof activeTab)}
                className={`flex items-center gap-2 px-6 py-3 rounded-lg font-medium transition-all ${
                  activeTab === key
                    ? 'bg-primary-500 text-white shadow-sm'
                    : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'
                }`}
              >
                <Icon className="w-4 h-4" />
                {label}
              </button>
            ))}
          </div>
        </div>

        {/* Tab Content */}
        <AnimatePresence mode="wait">
          <motion.div
            key={activeTab}
            initial={{ opacity: 0, y: 10 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -10 }}
            transition={{ duration: 0.3 }}
          >
            {activeTab === 'templates' && renderTemplates()}
            {activeTab === 'builder' && renderBuilder()}
            {activeTab === 'analytics' && renderAnalytics()}
          </motion.div>
        </AnimatePresence>

        {/* Node Configuration Panel */}
        <AnimatePresence>
          {selectedNode && (
            <motion.div
              initial={{ opacity: 0, x: 300 }}
              animate={{ opacity: 1, x: 0 }}
              exit={{ opacity: 0, x: 300 }}
              className="fixed right-4 top-1/2 transform -translate-y-1/2 w-80 bg-white rounded-2xl shadow-2xl border border-gray-200 p-6 z-50"
            >
              <div className="flex items-center justify-between mb-4">
                <h4 className="font-semibold text-text-primary">Configure Node</h4>
                <button
                  onClick={() => setSelectedNode(null)}
                  className="p-2 hover:bg-gray-100 rounded-lg"
                >
                  <Trash2 className="w-4 h-4 text-gray-500" />
                </button>
              </div>

              <div className="space-y-4">
                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Node Label
                  </label>
                  <input
                    type="text"
                    value={selectedNode.label}
                    className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-primary-500"
                  />
                </div>

                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-1">
                    Description
                  </label>
                  <textarea
                    rows={3}
                    className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-primary-500"
                    placeholder="Optional description for this step..."
                  />
                </div>

                {selectedNode.type === 'action' && (
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-2">
                      Action Settings
                    </label>
                    <div className="space-y-3">
                      <div>
                        <label className="text-sm text-gray-600">Email Template</label>
                        <select className="w-full px-3 py-2 border border-gray-300 rounded-lg">
                          <option>Welcome Email</option>
                          <option>Follow-up Email</option>
                          <option>Reminder Email</option>
                        </select>
                      </div>
                      <div>
                        <label className="text-sm text-gray-600">Delay (minutes)</label>
                        <input
                          type="number"
                          defaultValue={0}
                          className="w-full px-3 py-2 border border-gray-300 rounded-lg"
                        />
                      </div>
                    </div>
                  </div>
                )}

                {selectedNode.type === 'condition' && (
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-2">
                      Condition Settings
                    </label>
                    <div className="space-y-3">
                      <div>
                        <label className="text-sm text-gray-600">Field</label>
                        <select className="w-full px-3 py-2 border border-gray-300 rounded-lg">
                          <option>Client Type</option>
                          <option>Policy Value</option>
                          <option>Response Time</option>
                        </select>
                      </div>
                      <div>
                        <label className="text-sm text-gray-600">Operator</label>
                        <select className="w-full px-3 py-2 border border-gray-300 rounded-lg">
                          <option>Equals</option>
                          <option>Greater than</option>
                          <option>Less than</option>
                          <option>Contains</option>
                        </select>
                      </div>
                      <div>
                        <label className="text-sm text-gray-600">Value</label>
                        <input
                          type="text"
                          placeholder="Enter value..."
                          className="w-full px-3 py-2 border border-gray-300 rounded-lg"
                        />
                      </div>
                    </div>
                  </div>
                )}

                <div className="flex gap-2">
                  <button className="flex-1 btn-primary px-4 py-2 rounded-lg text-sm">
                    Save Changes
                  </button>
                  <button className="px-4 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">
                    <Copy className="w-4 h-4" />
                  </button>
                </div>
              </div>
            </motion.div>
          )}
        </AnimatePresence>
      </div>
    </section>
  );
}